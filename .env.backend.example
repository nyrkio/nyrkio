# Nyrkio Backend Environment Variables
# Copy this file to .env.backend and fill in the values

# =============================================================================
# DATABASE
# =============================================================================
DB_URL=mongodb://mongodb.nyrkio.local:27017/mongodb
DB_NAME=nyrkiodb

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# Secret key for JWT token signing (generate with: openssl rand -hex 32)
SECRET_KEY=

# Server hostname for cookie domain and CSRF validation
# Examples:
#   - localhost (development)
#   - nyrkio.com (production)
#   - staging.nyrkio.com (staging)
SERVER_NAME=localhost

# Override cookie domain explicitly (default: SERVER_NAME, or None for localhost)
# COOKIE_DOMAIN=

# Force secure cookies (default: auto-detected based on SERVER_NAME)
# Set to '1', 'true', 'yes', 'y', or 'on' to enable, '0', 'false', 'no', 'n', 'off' to disable
# COOKIE_SECURE=

# =============================================================================
# CSRF PROTECTION
# =============================================================================
# Additional allowed origins for CSRF validation (comma-separated).
# The server's own hostname (SERVER_NAME) is always automatically allowed,
# along with its www/non-www variant.
#
# Pattern formats:
#   - example.com        : Exact hostname match
#   - .example.com       : Matches example.com AND all subdomains (e.g., api.example.com)
#   - *.example.com      : Matches subdomains ONLY (e.g., api.example.com, but NOT example.com)
#
# Examples:
#   CSRF_ALLOWED_HOSTS=.other-domain.com,api.partner.com
#   CSRF_ALLOWED_ORIGINS=*.trusted-app.com,.external-service.io
#
# Note: CSRF_ALLOWED_HOSTS and CSRF_ALLOWED_ORIGINS are equivalent;
# use whichever name is more descriptive for your use case.
# CSRF_ALLOWED_HOSTS=
# CSRF_ALLOWED_ORIGINS=

# =============================================================================
# OAUTH / GITHUB
# =============================================================================
GITHUB_CLIENT_SECRET=
# GitHub token for API access (optional, for GitHub integration)
# GITHUB_TOKEN=

# =============================================================================
# EMAIL (Postmark)
# =============================================================================
POSTMARK_API_KEY=

# =============================================================================
# STRIPE / BILLING
# =============================================================================
STRIPE_SECRET_KEY=

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Enable debug mode
# DEBUG=false
# NYRKIO_DEBUG=false

# Sentry DSN for error reporting
# SENTRY_DSN=

# =============================================================================
# HUNTER (Change Point Detection) - Optional
# =============================================================================
# HUNTER_CONFIG=/path/to/hunter/config.yaml
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=admin

# =============================================================================
# TESTING / DEVELOPMENT
# =============================================================================
# Set to 'True' when running tests
# NYRKIO_TESTING=False
